generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================================================================
// 1. ENUMS SYSTEM
// =========================================================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum BoardType {
  KANBAN
  SCRUM
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum TaskType {
  BUG
  TASK
  STORY
  EPIC
  SUBTASK
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LinkType {
  BLOCKS
  RELATES_TO
  DUPLICATES
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT_ADDED
  STATUS_CHANGED
  MENTION
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum GitEventType {
  PUSH
  MERGE
  PR_OPEN
  PR_CLOSED
  PR_MERGED
  BRANCH_CREATED
  BRANCH_DELETED
  TAG_CREATED
}

enum ChangeType {
  ADDED
  MODIFIED
  DELETED
  RENAMED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// =========================================================================
// 2. IDENTITY & TENANCY LAYER (Org -> Workspace -> Members)
// =========================================================================

model Organization {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?
  logoUrl     String?
  settings    Json?                @default("{}")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tags        MemberTag[]
  users       OrganizationMember[]
  workspaces  Workspace[]
  webhooks    Webhook[]
  gitIntegrations GitIntegration[]
  invitations Invitation[]
}

model OrganizationMember {
  id                   String            @id @default(cuid())
  organizationId       String
  userId               String
  role                 OrgRole           @default(MEMBER)
  joinedAt             DateTime          @default(now())
  tags                 MemberToTag[]
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceMemberships WorkspaceMember[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  name        String
  email       String   @unique
  avatarUrl   String?
  settings    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations      OrganizationMember[]
  workspaces         WorkspaceMember[]
  projectMemberships ProjectMember[]
  comments           Comment[]
  gitActivities      GitActivity[]
  assignedTasks      Task[]
  reportedTasks      Task[]                  @relation("ReporterTasks")
  timeLogs           TimeLog[]
  activityLogs       ActivityLog[]
  notificationActors Notification[]          @relation("NotificationActor")
  notifications      NotificationRecipient[]
  invitations        Invitation[]
}

model MemberTag {
  id             String   @id @default(cuid())
  name           String
  color          String?
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      MemberToTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model MemberToTag {
  organizationMemberId String
  memberTagId          String
  createdAt            DateTime @default(now())

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)
  memberTag          MemberTag          @relation(fields: [memberTagId], references: [id], onDelete: Cascade)

  @@id([organizationMemberId, memberTagId])
}

model WorkspaceMember {
  id             String        @id @default(cuid())
  workspaceId    String
  organizationId String
  userId         String
  role           WorkspaceRole @default(VIEWER)
  joinedAt       DateTime      @default(now())

  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationMember OrganizationMember @relation(fields: [organizationId, userId], references: [organizationId, userId], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([organizationId, userId])
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String?
  organizationId String
  settings       Json?    @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  projects      Project[]
  boards        Board[]
  tasks         Task[]
  sprints       Sprint[]
  gitActivities GitActivity[]
  invitations   Invitation[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Webhook {
  id             String       @id @default(cuid())
  url            String
  secret         String
  events         String[]
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model GitIntegration {
  id             String         @id @default(cuid())
  installationId String         @unique
  accessToken    String?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repositories   GitRepository[]

  @@index([organizationId])
}

// =========================================================================
// 3. PROJECT, BOARD & AGILE INFRASTRUCTURE
// =========================================================================

model Project {
  id                   String        @id @default(cuid())
  name                 String
  projectKey           String
  description          String?
  status               ProjectStatus @default(PLANNING)
  completionPercentage Float         @default(0)
  workspaceId          String
  ticketCounter        Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks        Task[]
  sprints      Sprint[]
  repositories GitRepository[]
  labels       Label[]
  boards       Board[]
  members      ProjectMember[]

  @@unique([workspaceId, projectKey])
  @@unique([id, workspaceId])
  @@index([workspaceId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  joinedAt  DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Board {
  id          String    @id @default(cuid())
  name        String
  type        BoardType @default(KANBAN)
  projectId   String
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project       @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns   BoardColumn[]

  @@index([projectId])
  @@index([workspaceId])
}

model BoardColumn {
  id        String     @id @default(cuid())
  name      String
  statusMap TaskStatus
  order     Int
  boardId   String
  createdAt DateTime   @default(now())

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

model Sprint {
  id          String       @id @default(cuid())
  name        String
  goal        String?
  status      SprintStatus @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  projectId   String
  workspaceId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project   Project   @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([id, projectId])
  @@index([projectId])
  @@index([workspaceId])
}

// =========================================================================
// 4. CORE ISSUES / TASKS & RELATIONSHIPS
// =========================================================================

model Task {
  id            String     @id @default(cuid())
  ticketNumber  Int
  title         String
  description   String?
  status        TaskStatus @default(TODO)
  priority      Priority   @default(MEDIUM)
  type          TaskType   @default(TASK)
  dueDate       DateTime?
  storyPoints   Int?
  timeEstimated Int?
  timeSpent     Int        @default(0)
  boardOrder    Float      @default(0.0)

  projectId     String
  workspaceId   String
  sprintId      String?
  boardColumnId String?
  assigneeId    String?
  reporterId    String?
  parentTaskId  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project   @relation(fields: [projectId, workspaceId], references: [id, workspaceId], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sprint Sprint? @relation(fields: [sprintId, projectId], references: [id, projectId], onDelete: NoAction)

  boardColumn BoardColumn? @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  assignee    User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User?        @relation("ReporterTasks", fields: [reporterId], references: [id], onDelete: SetNull)
  parent      Task?        @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks    Task[]       @relation("SubTasks")

  comments      Comment[]
  labels        TaskLabel[]
  attachments   Attachment[]
  timeLogs      TimeLog[]
  activityLogs  ActivityLog[]
  outgoingLinks TaskLink[]        @relation("SourceTask")
  incomingLinks TaskLink[]        @relation("TargetTask")
  gitActivities TaskGitActivity[]

  @@unique([projectId, ticketNumber])
  @@index([projectId])
  @@index([workspaceId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([parentTaskId])
  @@index([projectId, status, boardOrder])
}

model TaskLink {
  id           String   @id @default(cuid())
  type         LinkType @default(BLOCKS)
  sourceTaskId String
  targetTaskId String
  createdAt    DateTime @default(now())

  sourceTask Task @relation("SourceTask", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TargetTask", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

// =========================================================================
// 5. TASK METADATA, FEEDBACK & AUDITING
// =========================================================================

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String
  projectId String
  createdAt DateTime @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskLabel {
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  message   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  taskId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TimeLog {
  id       String   @id @default(cuid())
  minutes  Int
  comment  String?
  userId   String
  taskId   String
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  fieldName String?
  oldValue  String?
  newValue  String?
  action    String
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

// =========================================================================
// 6. SYSTEMS NOTIFICATIONS PIPELINE
// =========================================================================

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  entityId  String?
  actorId   String?
  createdAt DateTime         @default(now())

  actor      User?                   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@index([createdAt])
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String
  userId         String
  isRead         Boolean   @default(false)
  readAt         DateTime?

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, isRead])
}

// =========================================================================
// 7. DEVOPS INTEGRATION ENGINE
// =========================================================================

model GitRepository {
  id            String      @id @default(cuid())
  name          String
  provider      GitProvider
  repositoryUrl String
  defaultBranch String
  projectId     String
  gitIntegrationId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gitIntegration GitIntegration? @relation(fields: [gitIntegrationId], references: [id], onDelete: SetNull)
  activities GitActivity[]

  @@index([projectId])
  @@index([gitIntegrationId])
}

model GitActivity {
  id            String       @id @default(cuid())
  eventType     GitEventType
  branchName    String
  commitHash    String?
  commitMessage String?
  repositoryId  String
  userId        String
  workspaceId   String
  eventTime     DateTime
  filesChanged  Int          @default(0)
  linesAdded    Int          @default(0)
  linesRemoved  Int          @default(0)
  rawPayload    Json
  createdAt     DateTime     @default(now())

  repository  GitRepository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fileChanges GitFileChange[]
  tasks       TaskGitActivity[]

  @@index([repositoryId])
  @@index([userId])
  @@index([workspaceId])
  @@index([eventTime])
}

model TaskGitActivity {
  taskId        String
  gitActivityId String
  createdAt     DateTime @default(now())

  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  gitActivity GitActivity @relation(fields: [gitActivityId], references: [id], onDelete: Cascade)

  @@id([taskId, gitActivityId])
}

model GitFileChange {
  id            String     @id @default(cuid())
  filePath      String
  changeType    ChangeType
  linesAdded    Int        @default(0)
  linesRemoved  Int        @default(0)
  gitActivityId String
  createdAt     DateTime   @default(now())

  gitActivity GitActivity @relation(fields: [gitActivityId], references: [id], onDelete: Cascade)

  @@index([gitActivityId, filePath])
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  organizationId String
  workspaceId    String?
  role           OrgRole          @default(MEMBER)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([email])
  @@index([token])
}
