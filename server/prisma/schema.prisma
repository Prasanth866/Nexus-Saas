generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users      OrganizationMember[]
  workspaces Workspace[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceMemberships WorkspaceMember[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  name        String
  email       String   @unique
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizations OrganizationMember[]
  workspaces    WorkspaceMember[]
  comments      Comment[]
  gitActivities GitActivity[]
  assignedTasks Task[]
}

model WorkspaceMember {
  id             String        @id @default(cuid())
  workspaceId    String
  organizationId String
  userId         String
  role           WorkspaceRole @default(VIEWER)
  joinedAt       DateTime      @default(now())

  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationMember OrganizationMember @relation(fields: [organizationId, userId], references: [organizationId, userId], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
}

model Workspace {
  id             String   @id @default(cuid())
  name           String
  slug           String
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  projects     Project[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Project {
  id                   String        @id @default(cuid())
  name                 String
  projectKey           String
  description          String?
  status               ProjectStatus @default(PLANNING)
  completionPercentage Float         @default(0)
  workspaceId          String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks        Task[]
  sprints      Sprint[]
  repositories GitRepository[]
  labels       Label[]

  @@unique([workspaceId, projectKey])
  @@unique([id, workspaceId])
  @@index([workspaceId])
}

model Sprint {
  id        String       @id @default(cuid())
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  projectId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([id, projectId])
  @@index([projectId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  storyPoints  Int?
  projectId    String
  sprintId     String?
  assigneeId   String?
  parentTaskId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint   Sprint?     @relation(fields: [sprintId, projectId], references: [id, projectId], onDelete: NoAction)
  assignee User?       @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  parent   Task?       @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks Task[]      @relation("SubTasks")
  comments Comment[]
  labels   TaskLabel[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([parentTaskId])
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String
  projectId String
  createdAt DateTime @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskLabel {
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  message   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model GitRepository {
  id            String      @id @default(cuid())
  name          String
  provider      GitProvider
  repositoryUrl String
  defaultBranch String
  projectId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities GitActivity[]

  @@index([projectId])
}

model GitActivity {
  id            String       @id @default(cuid())
  eventType     GitEventType
  branchName    String
  commitHash    String?
  commitMessage String?
  repositoryId  String
  userId        String
  eventTime     DateTime

  filesChanged Int @default(0)
  linesAdded   Int @default(0)
  linesRemoved Int @default(0)

  rawPayload Json

  createdAt DateTime @default(now())

  repository  GitRepository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileChanges GitFileChange[]

  @@index([repositoryId])
  @@index([userId])
  @@index([eventTime])
}

model GitFileChange {
  id            String     @id @default(uuid())
  filePath      String
  changeType    ChangeType
  linesAdded    Int        @default(0)
  linesRemoved  Int        @default(0)
  gitActivityId String
  createdAt     DateTime   @default(now())

  gitActivity GitActivity @relation(fields: [gitActivityId], references: [id], onDelete: Cascade)

  @@index([gitActivityId, filePath])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum GitEventType {
  PUSH
  MERGE
  PR_OPEN
  PR_CLOSED
  PR_MERGED
  BRANCH_CREATED
  BRANCH_DELETED
  TAG_CREATED
}

enum ChangeType {
  ADDED
  MODIFIED
  DELETED
  RENAMED
}
